end)
function checkcaves()
	local c = 0
	for i,v in workspace:GetChildren() do
		if v.Name == "specificOresCave" and v.Anchored == false or v.Name == "whatsupguys" then
			c = c + 1
			table.insert(tablee,v)
			v.Name = "whatsupguys"
		end
	end

	return c
end
repeat task.wait() until checkcaves() >= 1
